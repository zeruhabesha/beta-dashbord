VITE_OPENSEARCH_PROXY_TARGET=http://196.188.249.46:9200
# Optional credentials for secured OpenSearch clusters:
# VITE_OPENSEARCH_PROXY_USERNAME=admin
# VITE_OPENSEARCH_PROXY_PASSWORD=your-password

# Local dev server binding. Keep this strict so another Vite app cannot
# silently occupy localhost:5173 and break iframe proxy routes.
# `npm run dev` now fails fast if anything is already listening on this port.
VITE_DEV_SERVER_HOST=localhost
VITE_DEV_SERVER_PORT=5173

# Live SIEM alert stream + case creation backend used by the custom SIEM page.
# Keep disabled unless the alert service is actually reachable; otherwise Vite
# will repeatedly proxy polling/SSE requests to a dead backend.
VITE_SIEM_ALERTS_ENABLED=false
# VITE_SIEM_ALERTS_PROXY_TARGET=http://127.0.0.1:8080
# Optional server-side auth passthrough when the alert API expects a static header.
# SIEM_ALERTS_PROXY_AUTHORIZATION=Bearer your-token

# Case Management and Ticketing backend used by the CMT React pages.
# The CMT backend routes are mounted at root: /auth, /cases, /alerts, etc.
# Leave empty when the React app is served behind the same reverse proxy as CMT.
VITE_CMT_API_BASE=
VITE_CMT_AUTO_CONNECT=true
VITE_CMT_REQUIRE_AUTH_SESSION=false
VITE_CMT_USE_KEYCLOAK_TOKEN=true
VITE_CMT_ENABLE_SSE=true
# VITE_CMT_PROXY_TARGET=http://127.0.0.1:8081

# Response service used by manual analyst actions.
# Browser calls stay same-origin through /api/response; the proxy forwards them
# to RESPONSE_SERVICE_PROXY_TARGET or VITE_RESPONSE_SERVICE_PROXY_TARGET.
VITE_PLAYBOOK_SERVICE_API=/api/playbooks
VITE_APPROVAL_SERVICE_API=/api/approvals
VITE_RESPONSE_SERVICE_API=/api/response
VITE_AUDIT_SERVICE_API=/api/audit-service
VITE_THREAT_HUNTING_SERVICE_API=/api/threat-hunting
VITE_SECURITY_SERVICES_ENABLED=false
# VITE_PLAYBOOK_SERVICE_PROXY_TARGET=http://127.0.0.1:9092
# VITE_RESPONSE_SERVICE_PROXY_TARGET=http://127.0.0.1:9093
# VITE_APPROVAL_SERVICE_PROXY_TARGET=http://127.0.0.1:9094
# VITE_THREAT_HUNTING_SERVICE_PROXY_TARGET=http://127.0.0.1:9095
# VITE_AUDIT_SERVICE_PROXY_TARGET=http://127.0.0.1:9096
# Optional server-side auth passthrough when Response_Service expects a static header.
# PLAYBOOK_SERVICE_PROXY_AUTHORIZATION=Bearer your-token
# RESPONSE_SERVICE_PROXY_AUTHORIZATION=Bearer your-token
# APPROVAL_SERVICE_PROXY_AUTHORIZATION=Bearer your-token
# THREAT_HUNTING_SERVICE_PROXY_AUTHORIZATION=Bearer your-token
# AUDIT_SERVICE_PROXY_AUTHORIZATION=Bearer your-token

# OpenSearch Dashboards UI proxy for iframe routes like /app/discover.
VITE_DASHBOARDS_PROXY_TARGET=http://196.188.249.46:5601

# Kibana base URL for the Unified (All Teams) module iframe views.
# When set, All Teams dashboards load from Kibana instead of OpenSearch Dashboards.
# Kibana must allow embedding (no restrictive X-Frame-Options / CSP frame-ancestors).
# VITE_KIBANA_BASE_URL=http://YOUR_KIBANA_HOST:5601
# Leave blank for a direct Dashboards target. Set a Kubernetes service proxy
# path here only when routing through the Kubernetes API server.
VITE_DASHBOARDS_PROXY_PATH=

# If the embedded iframe ever shows OpenSearch "Index patterns" instead of a
# dashboard, repair the saved-object mapping/data views before starting Vite:
# npm run opensearch:repair

# Kubernetes API access for tenant management.
# For local development, the easiest target is a running `kubectl proxy`.
VITE_KUBERNETES_PROXY_TARGET=http://127.0.0.1:8001
# Optional bearer token when talking directly to the Kubernetes API server:
# VITE_KUBERNETES_PROXY_TOKEN=your-token

# For direct Kind / Kubernetes API access over mTLS, prefer the non-VITE
# variables below so the secrets stay server-side in the proxy config.
# KUBERNETES_PROXY_TARGET=https://127.0.0.1:6443
# KUBERNETES_PROXY_CA_DATA=base64-pem-ca
# KUBERNETES_PROXY_CLIENT_CERT_DATA=base64-pem-client-cert
# KUBERNETES_PROXY_CLIENT_KEY_DATA=base64-pem-client-key

# When Dashboards sits behind the Kubernetes API proxy instead of a direct
# :5601 endpoint, point the Dashboards target at that proxy and set the path.
# VITE_DASHBOARDS_PROXY_TARGET=http://127.0.0.1:8001
# VITE_DASHBOARDS_PROXY_PATH=/api/v1/namespaces/logging/services/http:opensearch-dashboards:5601/proxy

# For the Docker-served UI on :8080, the easiest path is:
# powershell -ExecutionPolicy Bypass -File .\scripts\start-security-dashboard-with-kind.ps1
# That script reads the current Kind admin kubeconfig and starts the dashboard
# container with the right endpoint and client certificates.
